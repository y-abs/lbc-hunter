{
  "name": "lbc-hunter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && node scripts/build-content.js",
    "clean": "rm -rf dist",
    "lint:biome": "biome check src --max-diagnostics=200",
    "lint:sh": "find scripts -name '*.sh' -type f -exec shellcheck -S warning {} +",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:ci": "vitest run --reporter=verbose --coverage",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "idb": "^8.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^2.1.9",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^15.11.7",
    "prettier": "^3.8.3",
    "vite": "^5.0.0",
    "vite-plugin-static-copy": "^1.0.0",
    "vitest": "^2.1.9"
  }
}
