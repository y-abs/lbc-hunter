{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": ["src/**/*.js", "tests/**/*.js", "scripts/**/*.js", "*.js", "!dist", "!coverage", "!node_modules"]
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 120,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "recommended": true
      },
      "suspicious": {
        "recommended": true
      }
    }
  },
  "assist": {
    "enabled": false
  }
}
